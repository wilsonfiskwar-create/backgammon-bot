{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd server && npm install"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd server && node index.js",
    "healthcheckPath": "/",
    "sleepApplication": false,
    "restartPolicyType": "on-failure"
  }
}
